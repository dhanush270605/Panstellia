# Vite/Frontend environment variables (REQUIRED)
# These values are safe to expose to the browser.

VITE_RAZORPAY_KEY_ID=

# Vercel-hosted Firebase Functions endpoints (REST)
VITE_FIREBASE_CREATE_ORDER_URL=
VITE_FIREBASE_VERIFY_PAYMENT_URL=
VITE_FIREBASE_MARK_PAYMENT_FAILED_URL=

# Backend/Firebase Functions only. Never expose this as VITE_*.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ========== EmailJS Configuration - COMPLETELY FREE! ==========
# This enables automatic order notifications without any backend server
# 
# Setup Instructions:
# 1. Sign up free at: https://www.emailjs.com/
# 2. Add your email service (Gmail recommended)
# 3. Create email templates in EmailJS dashboard
# 4. Get your credentials and paste below

# Your EmailJS Service ID (copy from EmailJS Dashboard -> Services)
VITE_EMAILJS_SERVICE_ID=service_91mvdyj

# Your EmailJS Template ID for Admin Notifications
# This template receives new order notifications
VITE_EMAILJS_TEMPLATE_ID_ORDER=template_pmo5qzx

# Your EmailJS Template ID for Customer Confirmations
# This template sends order confirmation to customers
VITE_EMAILJS_TEMPLATE_ID_CUSTOMER=template_sru5dx9

# Your EmailJS Public Key (copy from EmailJS Dashboard -> Account -> API Keys)
# This is safe to expose publicly (it's called PUBLIC key)
VITE_EMAILJS_PUBLIC_KEY=ievhBmWbKSZlZjrDj

# Admin email address to receive order notifications
VITE_ADMIN_EMAIL=support@panstellia.com
